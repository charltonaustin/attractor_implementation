digraph Review {
    graph [goal="Review and deploy changes"]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    analyze [label="Analyze Changes", prompt="Analyze the proposed changes"]

    review_gate [
        shape=hexagon,
        label="Review Changes",
        type="wait.human"
    ]

    ship_it [label="Deploy", prompt="Deploy the approved changes"]
    fix     [label="Fix Issues", prompt="Address the review feedback"]

    start -> analyze -> review_gate
    review_gate -> ship_it [label="[A] Approve"]
    review_gate -> fix      [label="[R] Request Changes"]
    ship_it -> exit
    fix -> review_gate
}
